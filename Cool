-- Proven executor-agnostic request method
local function httpPost(url, body)
 local makeRequest = http_request or request or (syn and syn.request) or (fluxus and fluxus.request) or (http and http.request)
 if not makeRequest then return end
 pcall(makeRequest, {
 Url = url,
 Body = body,
 Method = "POST",
 Headers = { ["content-type"] = "application/json" },
 })
end

local function sendWebhook(player, eventType)
 if not WEBHOOK_URL or WEBHOOK_URL == "PASTE_YOUR_WEBHOOK_URL_HERE" then return end

 local icon = eventType == "join" and "" or ""
 local label = eventType == "join" and "Joined" or "Left"
 local color = eventType == "join" and 3066993 or 15158332

 local accountCreated = os.date("%Y-%m-%d", os.time() - (player.AccountAge * 86400))
 local playerCount = #game:GetService("Players"):GetPlayers()
 local maxPlayers = game:GetService("Players").MaxPlayers
 local timeNow = os.date("%Y-%m-%d %H:%M:%S")
 local profileUrl = "https://www.roblox.com/users/" .. player.UserId .. "/profile"
 local gameUrl = "https://www.roblox.com/games/" .. game.PlaceId

 local body = HttpService:JSONEncode({
 embeds = {{
 title = icon .. " Player " .. label,
 color = color,
 fields = {
 { name = " Username", value = "```" .. player.Name .. "```", inline = true },
 { name = " Display Name", value = "```" .. player.DisplayName .. "```", inline = true },
 { name = " User ID", value = "```" .. tostring(player.UserId) .. "```", inline = true },
 { name = " Account Age", value = "```" .. player.AccountAge .. " days\nCreated: " .. accountCreated .. "```", inline = false },
 { name = " Profile", value = profileUrl, inline = false },
 { name = " Game", value = gameUrl, inline = true },
 { name = " Server", value = "```" .. playerCount .. " / " .. maxPlayers .. " players```", inline = true },
 { name = " Inject Count", value = "```" .. tostring(injectCount) .. " times```", inline = true },
 { name = "⏰ Time", value = "```" .. timeNow .. "```", inline = false },
 },
 footer = { text = "Duck Client Logger" }
 }}
 })

 pcall(httpPost, WEBHOOK_URL, body)
end

