-- 
-- Auto Dribble
-- 

local function startDribbleDetection()
 if dribbleLoop then dribbleLoop:Disconnect() dribbleLoop = nil end
 lastVelocity = Vector3.new(0, 0, 0)
 tackleCooldown = false

 dribbleLoop = RunService.Heartbeat:Connect(function()
 if not autoDribbleEnabled then return end
 local char = LocalPlayer.Character
 if not char then return end
 local root = char:FindFirstChild("HumanoidRootPart")
 if not root then return end

 local vel = root.AssemblyLinearVelocity
 local speedDrop = Vector3.new(lastVelocity.X,0,lastVelocity.Z).Magnitude
 - Vector3.new(vel.X,0,vel.Z).Magnitude

 if speedDrop > TACKLE_THRESHOLD and not tackleCooldown then
 tackleCooldown = true
 local look = root.CFrame.LookVector
 local boost = Vector3.new(look.X, 0, look.Z).Unit
 root.AssemblyLinearVelocity = boost * DRIBBLE_BOOST + Vector3.new(0, vel.Y, 0)
 notify("Auto Dribble", "Tackle dodged!", 1.5)
 task.delay(DRIBBLE_COOLDOWN, function() tackleCooldown = false end)
 end
 lastVelocity = vel
 end)
end

local function stopDribbleDetection()
 if dribbleLoop then dribbleLoop:Disconnect() dribbleLoop = nil end
 tackleCooldown = false
end

-- 
-- Generic box builder (accepts Vector3 size)
-- 

local function buildBox(root, sizeVec, transparency, canTouch, name, color)
 local box = Instance.new("Part")
 box.Name = name
 box.Size = sizeVec
 box.Transparency = transparency
 box.CanCollide = false
 box.CanQuery = false
 box.CanTouch = canTouch
 box.Massless = true
 box.CastShadow = false
 box.Material = Enum.Material.SmoothPlastic
 box.Color = color or Color3.fromRGB(0, 170, 255)
 box.CFrame = root.CFrame
 box.Parent = root.Parent

 local weld = Instance.new("WeldConstraint")
 weld.Part0 = root
 weld.Part1 = box
 weld.Parent = box
 return box
end

-- Overlap loop — oscillates only the X axis by 0.2 (enough to re-trigger boundary)
local function buildOverlapLoop(getBox, getSizeVec, getActive, params)
 local phase = 0
 return RunService.Heartbeat:Connect(function()
 local box = getBox()
 if not getActive() or not box or not box.Parent then return end
 phase = phase + 1
 local sv = getSizeVec()
 local osc = phase % 2 == 0 and 0 or -0.2
 box.Size = Vector3.new(sv.X + osc, sv.Y + osc, sv.Z + osc)
 local parts = workspace:GetPartsInPart(box, params)
 for _, part in pairs(parts) do box.Touched:Fire(part) end
 end)
end

