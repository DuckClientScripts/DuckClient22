local HttpService = game:GetService("HttpService")
local CONFIG_FOLDER = "FIFASuperSoccer"
local CONFIG_EXT = ".json"
if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end

local function serializeConfig()
 return HttpService:JSONEncode({
 hitboxSizeX=hitboxSizeX, hitboxSizeY=hitboxSizeY, hitboxSizeZ=hitboxSizeZ,
 transparencyValue=transparencyValue, noJitterMode=noJitterMode, isScriptActive=isScriptActive,
 jumpSizeX=jumpSizeX, jumpSizeY=jumpSizeY, jumpSizeZ=jumpSizeZ,
 jumpTransparencyValue=jumpTransparencyValue, jumpNoJitterMode=jumpNoJitterMode, jumpHitboxEnabled=jumpHitboxEnabled,
 tackleSizeX=tackleSizeX, tackleSizeY=tackleSizeY, tackleSizeZ=tackleSizeZ,
 tackleTransparencyValue=tackleTransparencyValue, tackleNoJitterMode=tackleNoJitterMode, tackleHitboxEnabled=tackleHitboxEnabled,
 autoDribbleEnabled=autoDribbleEnabled,
 TACKLE_THRESHOLD=TACKLE_THRESHOLD, DRIBBLE_BOOST=DRIBBLE_BOOST, DRIBBLE_COOLDOWN=DRIBBLE_COOLDOWN,
 })
end

local function applyConfig(cfg)
 hitboxSizeX=cfg.hitboxSizeX or hitboxSizeX; hitboxSizeY=cfg.hitboxSizeY or hitboxSizeY; hitboxSizeZ=cfg.hitboxSizeZ or hitboxSizeZ
 transparencyValue=cfg.transparencyValue or transparencyValue; noJitterMode=cfg.noJitterMode or false
 jumpSizeX=cfg.jumpSizeX or jumpSizeX; jumpSizeY=cfg.jumpSizeY or jumpSizeY; jumpSizeZ=cfg.jumpSizeZ or jumpSizeZ
 jumpTransparencyValue=cfg.jumpTransparencyValue or jumpTransparencyValue; jumpNoJitterMode=cfg.jumpNoJitterMode or false
 tackleSizeX=cfg.tackleSizeX or tackleSizeX; tackleSizeY=cfg.tackleSizeY or tackleSizeY; tackleSizeZ=cfg.tackleSizeZ or tackleSizeZ
 tackleTransparencyValue=cfg.tackleTransparencyValue or tackleTransparencyValue; tackleNoJitterMode=cfg.tackleNoJitterMode or false
 TACKLE_THRESHOLD=cfg.TACKLE_THRESHOLD or TACKLE_THRESHOLD
 DRIBBLE_BOOST=cfg.DRIBBLE_BOOST or DRIBBLE_BOOST
 DRIBBLE_COOLDOWN=cfg.DRIBBLE_COOLDOWN or DRIBBLE_COOLDOWN

 isScriptActive=cfg.isScriptActive or false
 if isScriptActive then createHitbox() else removeHitbox() end

 jumpHitboxEnabled=cfg.jumpHitboxEnabled or false
 if jumpHitboxEnabled then startJumpMonitor() else stopJumpMonitor() end

 tackleHitboxEnabled=cfg.tackleHitboxEnabled or false
 if not tackleHitboxEnabled then removeTackleHitbox() end

 autoDribbleEnabled=cfg.autoDribbleEnabled or false
 if autoDribbleEnabled then startDribbleDetection() else stopDribbleDetection() end

 updateGroundTransparency(); updateGroundSize()
 updateJumpTransparency(); updateJumpSize()
 updateTackleTransparency(); updateTackleSize()
end

local function configPath(n) return CONFIG_FOLDER.."/"..n..CONFIG_EXT end
local function listConfigs()
 local names={}
 for _,p in pairs(listfiles(CONFIG_FOLDER)) do
 local n=p:match("([^/\\]+)%.json$")
 if n then table.insert(names,n) end
 end
 table.sort(names); return names
end
local function saveConfig(n)
 if not n or n=="" then notify("Config","Enter a name first.",3) return end
 writefile(configPath(n),serializeConfig())
 notify("Config Saved","\""..n.."\" saved.",3)
end
local function loadConfig(n)
 if not n or n=="" then notify("Config","Enter a name first.",3) return end
 if not isfile(configPath(n)) then notify("Config","\""..n.."\" not found.",3) return end
 local ok,cfg=pcall(function() return HttpService:JSONDecode(readfile(configPath(n))) end)
 if ok and cfg then applyConfig(cfg) notify("Config Loaded","\""..n.."\" applied.",3)
 else notify("Config","Failed to parse.",3) end
end
local function deleteConfig(n)
 if not n or n=="" then notify("Config","Enter a name first.",3) return end
 if not isfile(configPath(n)) then notify("Config","\""..n.."\" not found.",3) return end
 delfile(configPath(n))
 notify("Config Deleted","\""..n.."\" deleted.",3)
end

local function getConfigOptions()
 local names=listConfigs()
 if #names==0 then return {"(no configs saved)"} end
 return names
end

