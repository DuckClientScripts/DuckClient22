 removeVisualBox()
 if hitboxPart and hitboxPart.Parent then hitboxPart:Destroy() end
 hitboxPart = nil
end

local function createHitbox()
 removeHitbox()
 local char = LocalPlayer.Character
 if not char then return end
 local root = char:FindFirstChild("HumanoidRootPart")
 if not root then return end
 groundParams.FilterDescendantsInstances = { char }

 local sv = groundSizeVec()
 if noJitterMode then
 hitboxPart = buildBox(root, sv, 1, true, "CleanHitbox", Color3.fromRGB(0,170,255))
 visualBox = buildBox(root, sv, transparencyValue, false, "VisualHitbox", Color3.fromRGB(0,170,255))
 else
 hitboxPart = buildBox(root, sv, transparencyValue, true, "CleanHitbox", Color3.fromRGB(0,170,255))
 end

 overlapLoop = buildOverlapLoop(
 function() return hitboxPart end,
 groundSizeVec,
 function() return isScriptActive end,
 groundParams
 )
end

