local tackleHitboxEnabled = false
local tackleSizeX = 25
local tackleSizeY = 17
local tackleSizeZ = 30 -- extra depth forward for the lunge
local tackleTransparencyValue = 0.8
local tackleHitboxPart = nil
local tackleVisualBox = nil
local tackleOverlapLoop = nil
local tackleNoJitterMode = false
local tackleKey = Enum.KeyCode.E

local UIS = game:GetService("UserInputService")

local function tackleSizeVec() return Vector3.new(tackleSizeX, tackleSizeY, tackleSizeZ) end

local function removeTackleVisualBox()
 if tackleVisualBox and tackleVisualBox.Parent then tackleVisualBox:Destroy() end
 tackleVisualBox = nil
end

local function removeTackleHitbox()
 if tackleOverlapLoop then tackleOverlapLoop:Disconnect() tackleOverlapLoop = nil end
 removeTackleVisualBox()
 if tackleHitboxPart and tackleHitboxPart.Parent then tackleHitboxPart:Destroy() end
 tackleHitboxPart = nil
end

local tackleParams = OverlapParams.new()
tackleParams.FilterType = Enum.RaycastFilterType.Exclude

local function createTackleHitbox()
 removeTackleHitbox()
 local char = LocalPlayer.Character
 if not char then return end
 local root = char:FindFirstChild("HumanoidRootPart")
 if not root then return end
 tackleParams.FilterDescendantsInstances = { char }

 local sv = tackleSizeVec()
 -- Offset forward so the box extends in front of the player during the lunge
 local forwardOffset = root.CFrame.LookVector * (tackleSizeZ / 4)

 if tackleNoJitterMode then
 tackleHitboxPart = buildBox(root, sv, 1, true, "TackleHitbox", Color3.fromRGB(255, 60, 60))
 tackleVisualBox = buildBox(root, sv, tackleTransparencyValue, false, "TackleVisualHitbox", Color3.fromRGB(255, 60, 60))
 tackleHitboxPart.CFrame = root.CFrame + forwardOffset
 tackleVisualBox.CFrame = root.CFrame + forwardOffset
 else
 tackleHitboxPart = buildBox(root, sv, tackleTransparencyValue, true, "TackleHitbox", Color3.fromRGB(255, 60, 60))
 tackleHitboxPart.CFrame = root.CFrame + forwardOffset
 end

 -- Re-weld offset from root using a Motor6D-style attachment offset
 -- WeldConstraint keeps it locked but positioned forward
 local att0 = Instance.new("Attachment")
 att0.Position = root.CFrame:VectorToObjectSpace(forwardOffset)
 att0.Parent = root

 local att1 = Instance.new("Attachment")
 att1.Parent = tackleHitboxPart

 local ap = Instance.new("AlignPosition")
 ap.Attachment0 = att1
 ap.Attachment1 = att0
 ap.RigidityEnabled = true
 ap.Parent = tackleHitboxPart

 local ao = Instance.new("AlignOrientation")
 ao.Attachment0 = att1
 ao.Attachment1 = att0
 ao.RigidityEnabled = true
 ao.Parent = tackleHitboxPart

 if tackleVisualBox then
 local vatt0 = Instance.new("Attachment")
 vatt0.Position = root.CFrame:VectorToObjectSpace(forwardOffset)
 vatt0.Parent = root
 local vatt1 = Instance.new("Attachment")
 vatt1.Parent = tackleVisualBox
 local vap = Instance.new("AlignPosition")
 vap.Attachment0 = vatt1
 vap.Attachment1 = vatt0
 vap.RigidityEnabled = true
 vap.Parent = tackleVisualBox
 local vao = Instance.new("AlignOrientation")
 vao.Attachment0 = vatt1
 vao.Attachment1 = vatt0
 vao.RigidityEnabled = true
 vao.Parent = tackleVisualBox
 end

 tackleOverlapLoop = buildOverlapLoop(
 function() return tackleHitboxPart end,
 tackleSizeVec,
 function() return tackleHitboxEnabled end,
 tackleParams
 )
end

local function updateTackleTransparency()
 if tackleNoJitterMode then
 if tackleVisualBox and tackleVisualBox.Parent then tackleVisualBox.Transparency = tackleTransparencyValue end
 else
 if tackleHitboxPart and tackleHitboxPart.Parent then tackleHitboxPart.Transparency = tackleTransparencyValue end
 end
end

local function updateTackleSize()
 local sv = tackleSizeVec()
 if tackleVisualBox and tackleVisualBox.Parent then tackleVisualBox.Size = sv end
end

-- Key listeners: spawn hitbox on E down, remove on E up
