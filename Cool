 if visualBox and visualBox.Parent then visualBox.Transparency = transparencyValue end
 else
 if hitboxPart and hitboxPart.Parent then hitboxPart.Transparency = transparencyValue end
 end
end

local function updateGroundSize()
 local sv = groundSizeVec()
 if visualBox and visualBox.Parent then visualBox.Size = sv end
 -- functional box size is handled by the oscillation loop live
end

