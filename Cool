-- 
-- Jump monitor — swaps hitboxes on air/ground change
-- 

local function startJumpMonitor()
 if jumpMonitorLoop then jumpMonitorLoop:Disconnect() jumpMonitorLoop = nil end
 wasAirborne = false

 jumpMonitorLoop = RunService.Heartbeat:Connect(function()
 if not jumpHitboxEnabled then return end
 local airborne = isAirborne()
 if airborne == wasAirborne then return end
 wasAirborne = airborne

 if airborne then
 if hitboxPart and hitboxPart.Parent then
 hitboxPart.CanTouch = false
 hitboxPart.Transparency = 1
 end
 if visualBox and visualBox.Parent then visualBox.Transparency = 1 end
 createJumpHitbox()
 else
 removeJumpHitbox()
 if hitboxPart and hitboxPart.Parent then
 hitboxPart.CanTouch = true
 updateGroundTransparency()
 end
 if visualBox and visualBox.Parent then updateGroundTransparency() end
 end
 end)
end

local function stopJumpMonitor()
 if jumpMonitorLoop then jumpMonitorLoop:Disconnect() jumpMonitorLoop = nil end
 removeJumpHitbox()
 if hitboxPart and hitboxPart.Parent then
 hitboxPart.CanTouch = true
 updateGroundTransparency()
 end
 wasAirborne = false
end

